# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Gmail Cleanup CLI environment variables
# Copy this file to `.env` and fill in your values.
# NEVER commit `.env` to Git — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ───────────────────────────────────────────────────────────────────

# Your Anthropic API key. Get one at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ─────────────────────────────────────────────────────────

# Override the Gmail MCP server URL if you are self-hosting or using a proxy.
# Default (used if not set): https://gmailmcp.googleapis.com/mcp/v1
# GMAIL_MCP_URL=https://gmailmcp.googleapis.com/mcp/v1

# Override the Anthropic model. Must support MCP tool use.
# Default: claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
