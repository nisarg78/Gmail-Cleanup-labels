# ─── Google OAuth2 ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Your app's public URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Secret for signing/encrypting session tokens
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ─── LLM Providers (optional) ─────────────────────────────────────────────────
# NOTE: LLM API keys are stored in your BROWSER (localStorage), not on the server.
# These env vars are NOT used by the app — they are documented here for reference.
# Configure your LLM provider in the Settings page after signing in.
#
# ANTHROPIC_API_KEY=sk-ant-...   ← stored in browser, NOT here
# OPENAI_API_KEY=sk-...          ← stored in browser, NOT here
